# SemtAğı — Backend Configuration Example

# Server
APP_PORT=3000
NODE_ENV=production

# Database (SQLite for local, PostgreSQL recommended for production)
DATABASE_URL="file:./dev.db"

# JWT Security
JWT_SECRET="gelisiguzel-bir-guvenlik-anahtari-buraya-gelmeli"
JWT_EXPIRES_IN="7d"

# CORS & Integration
# Comma separated list of allowed frontend URLs
FRONTEND_URLS="http://localhost:3001,http://localhost:3002,http://localhost:3003"

# SMTP (Email Verification)
SMTP_HOST="smtp.example.com"
SMTP_PORT=587
SMTP_USER="user@example.com"
SMTP_PASS="password"
SMTP_FROM="noreply@semtagi.com"
